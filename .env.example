# DataPulse — Root environment template
# This file documents variables for the full system (FastAPI server + streaming worker).
#
# For the FastAPI backend alone, see backend/.env.example
# For the React frontend alone, see frontend/.env.example
#
# Copy relevant sections to backend/.env and frontend/.env — do NOT commit those files.

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  FASTAPI BACKEND                                                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────────────────
# Production: full connection string overrides individual DB_* vars when set.
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_detection
DB_USER=postgres
DB_PASSWORD=

# Read-only user for the NL-to-SQL chatbot (Vanna)
DB_READONLY_USER=dp_readonly
DB_READONLY_PASSWORD=

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

ADMIN_USERNAME=admin
ADMIN_PASSWORD=datapulse2024

# ── CORS ───────────────────────────────────────────────────────────────────────
# In production, replace with your deployed frontend URL(s).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── NLP Chatbot (Vanna + Gemini) ───────────────────────────────────────────────
# Obtain a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  STREAMING WORKER  (kafka_consumer.py / streaming_worker.py only)           ║
# ║  Not read by the FastAPI server.                                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=creditcardtransaction
KAFKA_GROUP_ID=fraud-detection-consumer

# Redpanda Cloud SASL credentials (leave blank for local plaintext Kafka)
REDPANDA_USERNAME=
REDPANDA_PASSWORD=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  ML TRAINING SCRIPTS  (spark_*.py / vanna_train.py only)                   ║
# ║  Not read by the FastAPI server.                                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

SPARK_MASTER=local[*]
SPARK_APP_NAME=FraudDetection

# Absolute path to the PostgreSQL JDBC jar for Spark
POSTGRES_JDBC_JAR=/path/to/postgresql-42.x.x.jar

# JDBC connection for Spark (mirrors DATABASE_URL but in JDBC format)
POSTGRES_URL=jdbc:postgresql://localhost:5432/fraud_detection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Input data files used by training scripts
CUSTOMER_DATA_FILE=/path/to/data/customer.csv
TRANSACTION_DATA_FILE=/path/to/data/transactions.csv

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  REACT FRONTEND  (set in frontend/.env or hosting platform env vars)        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

VITE_API_BASE_URL=http://localhost:8000
VITE_WEBSOCKET_URL=ws://localhost:8000/ws
VITE_API_TIMEOUT=30000
VITE_REAL_TIME_UPDATE_INTERVAL=2000
VITE_ENV=development
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_MOCK_DATA=false
VITE_GOOGLE_CLIENT_ID=
