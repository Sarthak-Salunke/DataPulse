# ============================================================
# DataPulse — Environment Variable Template
# Copy this file to backend/.env and fill in your values.
# NEVER commit backend/.env with real secrets to version control.
# ============================================================

# ── PostgreSQL / TimescaleDB ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_detection
DB_USER=postgres
DB_PASSWORD=<your-postgres-password>

# Read-only user for the Vanna/Chatbot NL-to-SQL engine.
# Create with: CREATE USER dp_readonly WITH PASSWORD '...';
#              GRANT SELECT ON ALL TABLES IN SCHEMA public TO dp_readonly;
DB_READONLY_USER=<your-readonly-db-user>
DB_READONLY_PASSWORD=<your-readonly-db-password>

# ── Spark JDBC ───────────────────────────────────────────────
POSTGRES_URL=jdbc:postgresql://localhost:5432/fraud_detection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-postgres-password>

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=creditcardtransaction
KAFKA_GROUP_ID=fraud-detection-consumer

# Redpanda Cloud SASL credentials (leave blank for local plaintext Kafka)
REDPANDA_USERNAME=
REDPANDA_PASSWORD=

# ── Cloud Database ────────────────────────────────────────────
# Full connection URL overrides individual DB_* vars when set.
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ── CORS origins ──────────────────────────────────────────────
# Comma-separated. Override for production.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Spark ────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=FraudDetection
POSTGRES_JDBC_JAR=C:/Spark/spark/jars/postgresql-42.7.8.jar

# ── JWT Authentication ───────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<replace-with-long-random-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Dashboard Login ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<your-admin-password>

# ── NLP Chatbot (Vanna + Gemini) ─────────────────────────────
# Obtain a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>

# ── Data file paths (used by diagnostic scripts only) ────────
CUSTOMER_DATA_FILE=<absolute-path-to>/data/customer.csv
TRANSACTION_DATA_FILE=<absolute-path-to>/data/transactions.csv
